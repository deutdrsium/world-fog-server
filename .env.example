# 必填：JWT 签名密钥（至少 32 字节随机字符串）
# 生成方法：openssl rand -base64 32
WF_JWT_SECRET=REPLACE_WITH_32_BYTE_RANDOM_SECRET

# 服务器配置
WF_SERVER_HOST=0.0.0.0
WF_SERVER_PORT=8443
WF_SERVER_TLS_CERT=/etc/ssl/certs/api.xuefz.cn.pem
WF_SERVER_TLS_KEY=/etc/ssl/private/api.xuefz.cn-key.pem

# WebAuthn 配置
WF_WEBAUTHN_RP_ID=xuefz.cn
WF_WEBAUTHN_RP_DISPLAY_NAME=世界迷雾
WF_WEBAUTHN_RP_ORIGINS=https://xuefz.cn,https://api.xuefz.cn

# JWT 有效期（小时，默认 30 天）
WF_JWT_EXPIRY_HRS=720

# 数据库路径
WF_DB_PATH=/var/lib/world-fog/world-fog.db

# Apple 配置（必填，用于生成 AASA 文件）
WF_APPLE_TEAM_ID=ABCDE12345
WF_APPLE_BUNDLE_ID=cn.xuefz.worldfog
